# =============================================================
# KoTH CTF Platform — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================

# ── Database ──────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=koth
POSTGRES_USER=koth_admin
POSTGRES_PASSWORD=CHANGE_ME_db_password

# ── Redis ─────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=CHANGE_ME_random_secret_key
API_ADMIN_TOKEN=CHANGE_ME_admin_token
API_DEBUG=false

# ── Tick Engine ───────────────────────────────────────────────
TICK_INTERVAL=60
TICK_GRACE_PERIOD=300
TICK_FREEZE_BEFORE_END=1800
GAME_DURATION_HOURS=6

# ── Scoring ───────────────────────────────────────────────────
BASE_POINTS=10
PIVOT_MULTIPLIER=1.5
FIRST_BLOOD_BONUS=50
DEFENSE_STREAK_BONUS=5
SLA_PENALTY=true

# ── Scorebot ──────────────────────────────────────────────────
SCOREBOT_HOST=scorebot
SCOREBOT_PORT=8081
SCOREBOT_CHECK_TIMEOUT=15
HILL_SSH_USER=root
HILL_SSH_PASS=CHANGE_ME_hill_ssh_password

# ── VPN (optional — only if managing VPN through the platform) ──
VPN_SERVER_IP=
VPN_SUBNET=10.10.0.0/24
VPN_PORT=51820
VPN_SSH_PASS=CHANGE_ME_vpn_ssh_password

# ── Branding ──────────────────────────────────────────────────
EVENT_NAME=KoTH CTF
EVENT_SUBTITLE=King of the Hill Competition
REGISTRATION_CODE=CHANGE_ME_registration_code
